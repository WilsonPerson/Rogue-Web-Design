# Copy to ".env" and fill ONE of the options below (Vite only exposes vars prefixed with VITE_).

# Option A — Formspree: https://formspree.io — create a form, paste its POST URL
# VITE_FORMSPREE_URL=https://formspree.io/f/xxxxxxxx

# Option B — Web3Forms: https://web3forms.com — create an access key
# VITE_WEB3FORMS_ACCESS_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Option C — Opens the visitor's email app (no third party). Use a real inbox address.
VITE_CONTACT_EMAIL=roganshype@gmail.com
